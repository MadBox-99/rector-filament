{
    "name": "madbox-99/rector-filament",
    "description": "Rector rules for Filament codebases.",
    "type": "rector-extension",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "rector/rector": "^2.0",
        "filament/support": "^4.0 || ^5.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "Madbox99\\RectorFilament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Madbox99\\RectorFilament\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
